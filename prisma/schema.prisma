generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id            String                  @id @default(cuid())
  slug          String                  @unique
  order         Int                     @default(0)
  image         String?
  subCategories SubCategory[]
  translations  CategoryTranslation[]
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@map("categories")
}

model SubCategory {
  id           String                     @id @default(cuid())
  slug         String                     @unique
  order        Int                        @default(0)
  image        String?
  category     Category                   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  categoryId   String
  products     Product[]
  translations SubCategoryTranslation[]
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt

  @@index([categoryId])
  @@map("sub_categories")
}

model SubCategoryTranslation {
  id            String      @id @default(cuid())
  locale        String
  name          String
  description   String?
  subCategory   SubCategory @relation(fields: [subCategoryId], references: [id], onDelete: Cascade)
  subCategoryId String

  @@unique([subCategoryId, locale])
  @@map("sub_category_translations")
}

model CategoryTranslation {
  id          String   @id @default(cuid())
  locale      String
  name        String
  description String?
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId  String

  @@unique([categoryId, locale])
  @@map("category_translations")
}

model Product {
  id             String                 @id @default(cuid())
  slug           String                 @unique
  featured       Boolean                @default(false)
  order          Int                    @default(0)
  subCategory    SubCategory            @relation(fields: [subCategoryId], references: [id], onDelete: Restrict)
  subCategoryId  String
  images         ProductImage[]
  translations   ProductTranslation[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([subCategoryId])
  @@map("products")
}

model ProductTranslation {
  id          String  @id @default(cuid())
  locale      String
  title       String
  description String?
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId   String

  @@unique([productId, locale])
  @@map("product_translations")
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  order     Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  @@index([productId])
  @@map("product_images")
}

model HeroSlide {
  id           String                   @id @default(cuid())
  image        String
  order        Int                      @default(0)
  active       Boolean                  @default(true)
  translations HeroSlideTranslation[]
  createdAt    DateTime                 @default(now())

  @@map("hero_slides")
}

model HeroSlideTranslation {
  id       String    @id @default(cuid())
  locale   String
  badge    String?
  title    String
  subtitle String?
  slide    HeroSlide @relation(fields: [slideId], references: [id], onDelete: Cascade)
  slideId  String

  @@unique([slideId, locale])
  @@map("hero_slide_translations")
}

model ContactSubmission {
  id          String   @id @default(cuid())
  fullName    String
  email       String
  phone       String?
  projectType String
  description String
  locale      String   @default("fr")
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([isRead])
  @@index([createdAt])
  @@map("contact_submissions")
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("site_settings")
}

model AdminUser {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())

  @@map("admin_users")
}

model BlogPost {
  id           String                  @id @default(cuid())
  slug         String                  @unique
  image        String?
  published    Boolean                 @default(false)
  order        Int                     @default(0)
  translations BlogPostTranslation[]
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@index([published, createdAt])
  @@map("blog_posts")
}

model BlogPostTranslation {
  id          String   @id @default(cuid())
  locale      String
  title       String
  excerpt     String?
  content     String   @db.Text
  post        BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId      String

  @@unique([postId, locale])
  @@map("blog_post_translations")
}

model FaqItem {
  id           String               @id @default(cuid())
  order        Int                  @default(0)
  published    Boolean              @default(true)
  translations FaqItemTranslation[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([published, order])
  @@map("faq_items")
}

model FaqItemTranslation {
  id       String  @id @default(cuid())
  locale   String
  question String
  answer   String  @db.Text
  faqItem  FaqItem @relation(fields: [faqItemId], references: [id], onDelete: Cascade)
  faqItemId String

  @@unique([faqItemId, locale])
  @@map("faq_item_translations")
}

model ServiceItem {
  id           String                   @id @default(cuid())
  icon         String?
  order        Int                      @default(0)
  published    Boolean                  @default(true)
  translations ServiceItemTranslation[]
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  @@index([published, order])
  @@map("service_items")
}

model ServiceItemTranslation {
  id          String      @id @default(cuid())
  locale      String
  title       String
  summary     String
  detail      String      @db.Text
  serviceItem ServiceItem @relation(fields: [serviceItemId], references: [id], onDelete: Cascade)
  serviceItemId String

  @@unique([serviceItemId, locale])
  @@map("service_item_translations")
}

model TeamMember {
  id        String   @id @default(cuid())
  photo     String?
  email     String?
  phone     String?
  order     Int      @default(0)
  role      String   @default("member") // "lead" = Yönetici/Kurucu (üstte), "member" = diğerleri
  published Boolean  @default(true)
  translations TeamMemberTranslation[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, order])
  @@map("team_members")
}

model TeamMemberTranslation {
  id         String     @id @default(cuid())
  locale     String
  fullName   String
  title      String
  teamMember TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  teamMemberId String

  @@unique([teamMemberId, locale])
  @@map("team_member_translations")
}

model DigitalCatalog {
  id        String               @id @default(cuid())
  slug      String               @unique
  published Boolean              @default(false)
  order     Int                  @default(0)
  coverImage String?
  pages     DigitalCatalogPage[]
  translations DigitalCatalogTranslation[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@map("digital_catalogs")
}

model DigitalCatalogTranslation {
  id       String         @id @default(cuid())
  locale   String
  title    String
  catalog  DigitalCatalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  catalogId String

  @@unique([catalogId, locale])
  @@map("digital_catalog_translations")
}

model DigitalCatalogPage {
  id       String         @id @default(cuid())
  imageUrl String
  order   Int            @default(0)
  catalog DigitalCatalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  catalogId String

  @@index([catalogId])
  @@map("digital_catalog_pages")
}
