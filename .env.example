# ─── Docker Compose Variables ───
# These are interpolated into docker-compose.yaml
DB_PASSWORD="generate-strong-password-here"
POSTGRES_DB="arvesta_db"
POSTGRES_USER="postgres"

# ─── Local Dev (direct connection, not via Docker) ───
DATABASE_URL="postgresql://postgres:your-password@localhost:5432/arvesta_db"

# ─── Auth ───
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="https://arvestafrance.com"
AUTH_TRUST_HOST="true"

# ─── Seed (optional, first deploy only) ───
# SEED_ADMIN_PASSWORD="your-admin-password"

# ─── Demo mode (optional) ───
# NEXT_PUBLIC_DEMO_MODE="true"
# DEMO_USERNAME="admin"
# DEMO_PASSWORD="your-demo-password"

# ─── SEO & Analytics ───
NEXT_PUBLIC_SITE_URL="https://arvesta-france.com"
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
