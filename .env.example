# Database
DB_PASSWORD="generate-strong-password-here"
POSTGRES_DB="arvesta_db"
POSTGRES_USER="postgres"
# Required for Prisma/scripts (local direct connection)
# Example: postgresql://postgres:your-password@localhost:5432/arvesta_db
DATABASE_URL=""

# Auth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="https://yourdomain.com"
AUTH_TRUST_HOST="true"

# Demo mode (temporary)
# NEXT_PUBLIC_DEMO_MODE="true"
# DEMO_MODE="true"
# DEMO_USERNAME="admin"
# DEMO_PASSWORD="your-demo-password"

# Optional: TinyPNG
# TINYPNG_API_KEY=""
# UPLOAD_ENABLE_TINYPNG="false"
